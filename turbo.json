{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "dependsOn": ["@repo/db#db:generate"],
      "cache": false,
      "persistent": true
    },
    "backend#dev": {
      "dependsOn": ["@repo/db#db:generate"],
      "with": ["price-ingestor#dev"],
      "cache": false,
      "persistent": true
    },
    "engine#dev": {
      "dependsOn": ["@repo/db#db:generate"],
      "with": ["price-ingestor#dev", "engine-worker#dev"],
      "cache": false,
      "persistent": true
    },
    "ws#dev": {
      "dependsOn": ["@repo/db#db:generate"],
      "with": ["price-ingestor#dev"],
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:deploy": {
      "cache": false
    },
    "timescale:schema": {
      "cache": false
    }
  }
}
