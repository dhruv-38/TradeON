{
  "name": "TradeON",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "turbo run db:generate --filter=@repo/db",
    "db:migrate": "turbo run db:migrate --filter=@repo/db",
    "timescale:schema": "turbo run timescale:schema --filter=@repo/timescaledb",
    "timescale:backfill": "turbo run timescale:backfill --filter=@repo/timescaledb",
    "setup": "bun run db:generate && bun run db:migrate && bun run timescale:schema"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "dotenv": "^17.4.2",
    "redis": "^5.12.1",
    "zod": "^4.4.3"
  }
}
