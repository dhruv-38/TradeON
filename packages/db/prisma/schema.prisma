// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())

  name      String
  email     String   @unique
  password  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  wallet    Wallet?

  @@index([email])
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
}

enum Symbol {
  BTC_USDC
  ETH_USDC
  SOL_USDC
}

enum OrderStatus {
  PENDING
  OPEN
  FILLED
  CANCELLED
  REJECTED
}

model Order {
  id           Int        @id @default(autoincrement())
  userId       Int
  user         User       @relation(fields: [userId],references: [id])
  orderType    OrderType
  side         OrderSide
  symbol       Symbol
  qty          Decimal
  leverage     Int
  takeProfit   Decimal?
  stopLoss     Decimal?
  slippage     Decimal?
  marginUsed   Decimal
  executionPrice Decimal?
  closePrice   Decimal?
  executedAt   DateTime?
  closeTime    DateTime?
  profitLoss   Decimal?
  status       OrderStatus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([symbol])
}

enum LedgerType {
  DEPOSIT
  WITHDRAWAL
  ORDER_RESERVE
  ORDER_RELEASE
  TRADE
  FEE
  REFUND
}

enum LedgerStatus {
  PENDING
  COMPLETED
  FAILED
}

model Wallet {
  id                Int      @id @default(autoincrement())

  userId            Int      @unique
  user              User     @relation(fields: [userId], references: [id])

  asset             String   @default("USD")

  availableBalance  Decimal  @default(0)
  lockedBalance     Decimal  @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ledgerEntries     LedgerEntry[]
}

model LedgerEntry {
  id              Int            @id @default(autoincrement())

  walletId        Int
  wallet          Wallet         @relation(fields: [walletId], references: [id])

  amount          Decimal
  type            LedgerType
  status          LedgerStatus

  referenceId     Int?
  referenceType   String?

  description     String?

  createdAt       DateTime       @default(now())
  @@index([walletId])
  @@index([referenceId, referenceType])
}

